    &gt;https://www.bilibili.com/video/BV15f4y157a6/?vd_source=f22a0f999f0aae1e6b4de06efdc8d78d&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;hugo 中文文档 &lt;a class=&#34;link&#34; href=&#34;https://www.gohugo.org/&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;https://www.gohugo.org/&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;https://docs.stack.jimmycai.com/zh/writing/&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;https://docs.stack.jimmycai.com/zh/writing/&lt;/a&gt;&lt;/li&gt;
